    "    \"# 读取 2010 年的租金数据，并规范化列名，剔除无关的数据列\\n\",\n",
    "    \"rent10 = pd.read_csv('../data/ACS_10_1YR_B25058_metro_micro/ACS_10_1YR_B25058.csv')\\n\",\n",
