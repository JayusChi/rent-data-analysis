    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# 定义底图颜色\\n\",\n",
    "    \"land_color = '#f5f5f3'        #陆地\\n\",\n",
    "    \"water_color = '#cdd2d4'       #水域\\n\",\n",
    "    \"coastline_color = '#666666'   #海岸线\\n\",\n",
    "    \"border_color = '#999999'      #边界线\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 定制化生成一组渐变色彩（从蓝色到红色的过渡色，无绿色）\\n\",\n",
    "    \"color_map = cm.get_cmap('brg')\\n\",\n",
    "    \"increments = [x*.6/float(num_bins) for x in range(num_bins)]\\n\",\n",
    "    \"# 生成 5 个渐变颜色的列表，对应 5 个分位数分类\\n\",\n",
    "    \"# 每个颜色对应一个分箱（0 = 蓝，1 = 深蓝紫，2 = 紫蓝，3 = 红紫，4 = 深红）\\n\",\n",
    "    \"color_list = color_map(increments).tolist()\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stderr\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"C:\\\\Users\\\\14794\\\\AppData\\\\Local\\\\Temp\\\\ipykernel_42420\\\\1268781819.py:8: MatplotlibDeprecationWarning: The get_cmap function was deprecated in Matplotlib 3.7 and will be removed in 3.11. Use ``matplotlib.colormaps[name]`` or ``matplotlib.colormaps.get_cmap()`` or ``pyplot.get_cmap()`` instead.\\n\",\n",
    "      \"  color_map = cm.get_cmap('brg')\\n\"\n",
    "     ]\n",
