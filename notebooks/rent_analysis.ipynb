    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# 筛选 2010 - 2014 年租金增长率并绘制增长最快 Top10 柱状图\\n\",\n",
    "    \"df_sorted = df.sort_values(by='rent_change_pct', ascending=False)\\n\",\n",
    "    \"top10_rent_growth = df_sorted[['geo_id_14','msa_name','city_state','rent_change_pct']].head(10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 绘制柱状图\\n\",\n",
    "    \"plt.figure(figsize=(10,8))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 绘图数据\\n\",\n",
    "    \"x = top10_rent_growth['city_state']\\n\",\n",
