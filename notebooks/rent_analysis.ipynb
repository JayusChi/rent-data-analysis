    "   \"source\": [\n",
    "    \"# 通过将数据集划分为5个等份来创建分类变量\\n\",\n",
    "    \"# 避免极端值影响：比如少数高租金城市会导致等距分箱的大部分样本集中在低档位，分位数分箱能保证每个档位的样本数均衡\\n\",\n",
    "    \"num_bins = 5\\n\",\n",
    "    \"bin_labels = range(num_bins)\\n\",\n",
    "    \"df['rent_cat'] = pd.qcut(x=df['median_contract_rent'], q=num_bins, labels=bin_labels)\\n\",\n",
    "    \"df['rent_change_cat'] = pd.qcut(x=df['rent_change_pct'], q=num_bins, labels=bin_labels)\\n\",\n",
