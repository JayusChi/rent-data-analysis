    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# 将百分比数据增加百分号，正负分明\\n\",\n",
    "    \"def format_pct(pct):\\n\",\n",
    "    \"    pct = round(pct, 1)    # 四舍五入到1位小数\\n\",\n",
    "    \"    prefix = '+' if pct > 0 else ''\\n\",\n",
    "    \"    return '{}{}%'.format(prefix, pct)\\n\",\n",
    "    \"\\n\",\n",
