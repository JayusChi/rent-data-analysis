    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# 绘制2014年中位租金与2010年中位租金的对比图\\n\",\n",
    "    \"fig, ax = plt.subplots()\\n\",\n",
    "    \"fig.set_size_inches(7, 7)\\n\",\n",
    "    \"axis_min = 0\\n\",\n",
    "    \"axis_max = 1800\\n\",\n",
    "    \"\\n\",\n",
    "    \"# regress 2014 rent on 2010 rent\\n\",\n",
    "    \"# 将 2014 年中位租金对 2010 年中位租金进行回归\\n\",\n",
    "    \"X = df['median_rent_10']\\n\",\n",
    "    \"Y = df['median_contract_rent']\\n\",\n",
    "    \"results = sm.OLS(Y, sm.add_constant(X)).fit()   # 核心作用是量化 “2010 年租金每涨 1 美元，2014 年租金涨多少”\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 计算回归线的估计y值\\n\",\n",
    "    \"X_line = X.copy()\\n\",\n",
    "    \"# 手动给 X 轴添加 “最小值 0” 和 “最大值 1800” 的点，确保回归线能覆盖整个坐标轴范围（从 0 到 1800 美元）\\n\",\n",
    "    \"X_line.loc[axis_min] = axis_min\\n\",\n",
    "    \"X_line.loc[axis_max] = axis_max\\n\",\n",
    "    \"# 根据回归系数计算回归线的 Y 坐标（2014 年预测租金）\\n\",\n",
    "    \"Y_est = X_line * results.params['median_rent_10'] + results.params['const']\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 绘制点、回归线和1:1线性关系线\\n\",\n",
    "    \"# ax.plot([axis_min, axis_max], [axis_min, axis_max], 'k-', color='k', alpha=0.3, linewidth=2)\\n\",\n",
    "    \"ax.plot(X_line, Y_est, c='#333333', alpha=0.4, linewidth=2)\\n\",\n",
    "    \"# 绘制散点图（每个点代表一个大都市区）\\n\",\n",
    "    \"ax.scatter(X, Y, c='m', edgecolor='#333333', alpha=0.4, s=50)\\n\",\n",
    "    \"\\n\",\n",
    "    \"ax.set_xlim([axis_min, axis_max])\\n\",\n",
    "    \"ax.set_ylim([axis_min, axis_max])\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 2014年与2010年各大都市区的中位数租金\\n\",\n",
    "    \"ax.set_title('2010 vs 2014 年美国大都市区中位租金散点图（含回归趋势线）', fontproperties=title_font, size=15)\\n\",\n",
    "    \"ax.set_xlabel('2010 年中位租金', fontproperties=label_font)\\n\",\n",
    "    \"ax.set_ylabel('2014 年中位租金', fontproperties=label_font)\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig.tight_layout()\\n\",\n",
    "    \"fig.savefig('../images/2010 vs 2014 年美国大都市区中位租金散点图（含回归趋势线）.png', dpi=300)\\n\",\n",
    "    \"plt.show()\"\n",
    "   ],\n",
