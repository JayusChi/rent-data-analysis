    "    \"plt.bar(x, y, color='#2E86AB', alpha=0.8, width=0.6)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 旋转字体防止堆叠\\n\",\n",
    "    \"plt.xticks(\\n\",\n",
    "    \"    rotation=45,\\n\",\n",
    "    \"    fontsize=12  # 调整横轴文字大小，进一步避免拥挤\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.grid(axis='y')\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.title('2010 - 2014 年租金增长率最大的十个地区',size=20)\\n\",\n",
    "    \"plt.xlabel('大都市区名称',size=15)\\n\",\n",
    "    \"plt.ylabel('租金增长率',size=15)\\n\",\n",
    "    \"\\n\",\n",
