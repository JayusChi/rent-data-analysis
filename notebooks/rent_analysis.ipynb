    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# 绘制美国区域的地理底图，并将经纬度格式的点数据按指定分类（cat）用不同颜色散点标注在地图上\\n\",\n",
    "    \"# 用于绘制底图并散点显示点数据的函数\\n\",\n",
    "    \"def draw_map(cat, title):\\n\",\n",
    "    \"    # 指定地图的宽度和高度，约为美国地图尺寸\\n\",\n",
    "    \"    map_width_m = 5000 * 1000   #5000 km\\n\",\n",
    "    \"    map_height_m = 3500 * 1000  #3500 km\\n\",\n",
    "    \"    plt.figure(figsize=[10, 10*(map_height_m/float(map_width_m))]) #使图形具有相同的高度：宽度比例\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 阿尔伯斯等积圆锥投影\\n\",\n",
    "    \"    m = Basemap(ellps='WGS84', projection='aea', lat_1=33, lat_2=45, lon_0=-98.4, lat_0=39,\\n\",\n",
    "    \"                width=map_width_m, height=map_height_m, resolution='l', area_thresh=10000, fix_aspect=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    m.drawcoastlines(color=coastline_color)     # 绘制海岸线\\n\",\n",
    "    \"    m.drawcountries(color=border_color)         # 绘制国家边界\\n\",\n",
    "    \"    m.drawstates(color=border_color)            # 绘制各州边界\\n\",\n",
    "    \"    m.fillcontinents(color=land_color, lake_color=water_color)   # 填充陆地颜色、湖泊颜色\\n\",\n",
    "    \"    m.drawmapboundary(fill_color=water_color)   # 填充地图边界外的区域（海洋）为水域色\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 绘制经纬度数据，每个区间使用不同的颜色\\n\",\n",
    "    \"    for color, n in zip(color_list, range(num_bins)):\\n\",\n",
    "    \"        subset = df[df[cat]==n]\\n\",\n",
    "    \"        # 将原始的经纬度（地理坐标）转换为 Basemap 投影后的平面坐标（x,y）\\n\",\n",
    "    \"        x, y = m(np.array(subset['longitude']), np.array(subset['latitude']))\\n\",\n",
    "    \"        m.scatter(x=x, y=y, s=200, color=color, edgecolor='#555555', alpha=0.7, zorder=10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    fig = plt.gcf()\\n\",\n",
    "    \"    fig.tight_layout()\\n\",\n",
    "    \"    fig.savefig('../images/{}.png'.format(title), dpi=300)\\n\",\n",
    "    \"    plt.show()\"\n",
    "   ],\n",
